# Copiază ca `.env.prod` și umple cu valori reale. NU commit-ui `.env.prod`.
#
# Pentru generare secrets random:
#   openssl rand -hex 32     # JWT_SECRET (64 hex chars)
#   openssl rand -base64 24  # POSTGRES_PASSWORD / MINIO_ROOT_PASSWORD

# ── Domeniu (A record pointat la IP-ul VPS-ului) ────────────────────────
DOMAIN=app.exemplu.ro

# ── Postgres ────────────────────────────────────────────────────────────
POSTGRES_USER=adeplast
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM
POSTGRES_DB=adeplast_saas
DATABASE_URL=postgresql+asyncpg://adeplast:CHANGE_ME_STRONG_RANDOM@db:5432/adeplast_saas

# ── MinIO (object storage pentru poze) ──────────────────────────────────
MINIO_ROOT_USER=adeplast
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_RANDOM
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=adeplast
MINIO_SECRET_KEY=CHANGE_ME_STRONG_RANDOM
MINIO_BUCKET=adeplast-photos
MINIO_SECURE=false

# ── App ─────────────────────────────────────────────────────────────────
APP_ENV=prod
JWT_SECRET=GENERATE_64_HEX_CHARS_WITH_openssl_rand_hex_32
JWT_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

FRONTEND_URL=https://app.exemplu.ro
CORS_ALLOWED_ORIGINS=https://app.exemplu.ro
